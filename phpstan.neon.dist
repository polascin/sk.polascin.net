parameters:
    # Začni nízko (0–4). Po vyčistení nálezov môžeš úroveň postupne zvyšovať až po 9.
    level: 4

    paths:
        - .

    excludePaths:
        - */vendor/*
        - */node_modules/*
        - tools/*.phar
        - .php-cs-fixer.dist.php

    # Existujúce nálezy sú v baseline — blokujú len NOVÉ chyby.
    # (Súbor naplní tools/install-dev-tools.ps1; placeholder je v repe, aby include nezlyhal.)

includes:
    - phpstan-baseline.neon
